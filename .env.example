# ============================================================
# Crypto Arbitrage Scanner — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Telegram (REQUIRED) ─────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal or group chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here


# ── Scanner Settings (OPTIONAL — defaults shown) ────────────

# Comma-separated list of exchanges to monitor
# Supported: binance, kraken, kucoin, bybit, okx
EXCHANGES=binance,kraken,kucoin,bybit,okx

# Comma-separated trading pairs to watch
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,SOL/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,AVAX/USDT

# Minimum spread % to trigger an alert (default: 0.5)
MIN_SPREAD_PCT=0.5

# Maximum spread % — anything higher is likely bad data (default: 20)
MAX_SPREAD_PCT=20.0

# Minimum 24h volume in USDT to consider a trading pair (default: 10000)
MIN_VOLUME_USDT=10000

# Seconds to wait before re-alerting the same pair/exchange combo (default: 300)
ALERT_COOLDOWN_SEC=300

# How often to scan for new prices, in seconds (default: 5)
SCAN_INTERVAL_SEC=5.0

# HTTP request timeout per exchange call, in seconds (default: 10)
REQUEST_TIMEOUT_SEC=10

# Max retries per exchange before giving up on a scan cycle (default: 3)
MAX_RETRIES=3

# Max concurrent exchange fetches (default: 5)
CONCURRENT_FETCHES=5


# ── Exchange API Keys (OPTIONAL) ────────────────────────────
# Public ticker data does NOT require API keys.
# Keys are only needed if you want to extend the bot for order execution.

# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# Kraken
KRAKEN_API_KEY=
KRAKEN_SECRET=

# KuCoin
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=

# OKX
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
